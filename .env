# MongoDB Atlas connection string (required for production)
DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/dotaibooks?retryWrites=true&w=majority

# Cloudinary credentials (for image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Legacy SQLite path (development only - not used in production)
# DATABASE_URL_SQLITE=file:./db/custom.db
